# git aliases.
alias clone="git clone"
alias gs="git status"
alias ga="git add"
alias gaa="git add -A"
alias gc="git commit"
alias gcp="git cherry-pick"
alias gl="git log | bat"
alias gr="git remote"
alias gra="git remote add"
alias grm="git remote rm"
alias grv="git remote -v"
alias gd="git diff"
alias gpl="git pull"

# Package aliases
alias install="yay -S"

# lvim aliases
alias lv="lvim"
alias zconfig="lvim ~/.zshrc"
alias aliases="lvim ~/.zsh/aliases.zsh"

# tmux aliases
alias tx="tmux"
alias txa="tmux attach -t"

